# ── JWT ───────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-use-a-strong-random-string-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ── Super Admin (seed criado no primeiro startup) ─────────────────────────────
SUPER_ADMIN_EMAIL=admin@yourdomain.com
SUPER_ADMIN_NAME=Admin Name
SUPER_ADMIN_PASSWORD=ChangeMe@Strong1
MASTER_ORG_NAME=Nome do Escritório

# ── SMTP2GO API (recuperação de senha) ───────────────────────────────────────
# Obtenha sua API Key em: app.smtp2go.com → Settings → API Keys
SMTP2GO_API_KEY=api-your-key-here
SMTP_FROM=noreply@yourdomain.com
SMTP_FROM_NAME=SGI Pro

# ── URLs ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
